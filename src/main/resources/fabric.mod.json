{
	"schemaVersion": 1,
	"id": "hex",
	"version": "${version}",
	"name": "Hex",
	"description": "Create. Collect. Wear. A community driven cosmetic project",
	"authors": [
		"Saaransh_Xd"
	],
	"contact": {
		"homepage": "https://hexcapes.qzz.io",
		"sources": "https://github.com/SaaranshDx/Hex"
	},
	"license": "MIT",
	"icon": "assets/hex/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "hex.capes.Hex",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "hex.capes.client.HexClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		"hex.mixins.json",
		{
			"config": "hex.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*"
	}
}
